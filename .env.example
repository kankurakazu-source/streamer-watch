# このファイルを .env にコピーして値を入力してください
# .env は絶対にGit管理下に置かない（.gitignoreに追加すること）

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
ANTHROPIC_API_KEY=

# X API v2は有料プラン(Basic以上)が必要。契約しない場合は空欄でOK（自動でスキップされます）
X_BEARER_TOKEN=

# スマホ確認用メール送信（Gmail）。GMAIL_APP_PASSWORD はGoogleの「アプリパスワード」。空欄なら送信スキップ
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
EMAIL_TO=
